@startuml

title gitita Publish Activity

start

:Push to main;

:publish.yml triggered;

:Detect changed articles;

if (New article?) then (yes)

  :Validate only one new article;

  if (Invalid?) then (yes)
    :Fail CI;
    stop
  endif

endif

:Validate frontmatter;

:Validate ownership;

:Validate image formats;

if (Validation failed?) then (yes)

  :Create GitHub Issue;
  :Assign author;
  :Fail CI;
  stop

endif

:Parse markdown;

:Detect local images;

:Upload images to Qiita;

if (Upload failed?) then (yes)

  :Create GitHub Issue;
  :Assign author;
  :Fail CI;
  stop

endif

:Replace image URLs in-memory;

if (qiita_id exists?) then (yes)
  :Update Qiita article;
else (no)
  :Create Qiita article;
  :Update qiita_id;
  :Bot commit to main;
endif

if (Publish failed?) then (yes)

  :Create GitHub Issue;
  :Assign author;
  :Fail CI;
  stop

endif

:Success;

stop

@enduml